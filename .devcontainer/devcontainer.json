{
  "name": "marketplace-server",
  "dockerComposeFile": ["../compose.dev.yml", "docker-compose.yml"],
  "service": "marketplace-server",
  "workspaceFolder": "/usr/src/app",
  "shutdownAction": "stopCompose",
  "remoteUser": "node",
  "forwardPorts": [3001, 5432, 6379],
  "portsAttributes": {
    "3001": {
      "label": "Marketplace API"
    },
    "5432": {
      "label": "Postgres"
    },
    "6379": {
      "label": "Redis"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
